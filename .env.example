# MongoDB connection string (required). Local example:
#   mongodb://127.0.0.1:27017/brainly
# Or a MongoDB Atlas SRV URI.
MONGODB_URI=

# Secret used to sign JWTs (required, >= 32 chars). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Port the API listens on. Defaults to 3001 if unset.
PORT=3001

# Comma-separated browser origins allowed by CORS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional — only needed for the YouTube playlist import feature.
YOUTUBE_API_KEY=
